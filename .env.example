# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — used for text-embedding-3-small (Tier 3 memory)
OPENAI_API_KEY=

# Supabase — use service_role key, not anon
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth credentials JSON path (Calendar + Gmail, same file)
GOOGLE_CREDENTIALS_PATH=

# Notion integration token — from notion.so/my-integrations
NOTION_API_KEY=

# Web search — Brave Search API (free tier: 2000 queries/month)
# Get from api.search.brave.com
WEB_SEARCH_API_KEY=

# OpenWeatherMap — free tier, no credit card
# Get from openweathermap.org/api
OPENWEATHER_API_KEY=

# Set after running Step 2 (insert user row in Supabase)
NOVA_USER_ID=

# Absolute path to workspace/ folder
NOVA_WORKSPACE_PATH=C:\Users\Kualar\Documents\AI\Nova\workspace
